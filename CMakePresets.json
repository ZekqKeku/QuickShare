{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "macos",
      "displayName": "QuickShare GUI Mac",
      "description": "Kompilacja natywnej paczki macOS (.app)",
      "binaryDir": "${sourceDir}/build/macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows",
      "displayName": "QuickShare Win",
      "description": "Kompilacja aplikacji okienkowej (.exe) dla Windows",
      "binaryDir": "${sourceDir}/build/windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "OS_TARGET": "Windows"
      }
    },
    {
      "name": "linux",
      "displayName": "QuickShare Linux Flatpak",
      "description": "Kompilacja pod paczkę Flatpak dla Linuxa",
      "binaryDir": "${sourceDir}/build/linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "environment": {
        "OS_TARGET": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos",
      "configurePreset": "macos"
    },
    {
      "name": "windows",
      "configurePreset": "windows"
    },
    {
      "name": "linux",
      "configurePreset": "linux"
    }
  ]
}
