   <string notr="true">
QMainWindow {
    background-color: #111218;
}

QWidget#centralwidget {
    background-color: #111218;
}

QTabWidget::pane {
    border-top: 1px solid #2d2e3a;
    background: #111218;
}

QTabBar::tab {
    background: transparent;
    color: #94a3b8;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
}

QTabBar::tab:selected {
    color: #3b82f6;
    border-bottom: 2px solid #3b82f6;
}

QTabBar::tab:hover:!selected {
    color: #f8fafc;
}

QLabel#label {
    border: 2px dashed #2d2e3a;
    border-radius: 8px;
    background-color: #1a1b23;
    color: #94a3b8;
    padding: 40px;
}

QLabel#label:hover {
    border-color: #3b82f6;
    background-color: #1e293b;
}

QPushButton#saveBtn {
    background-color: #3b82f6;
    color: white;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: 600;
}

QPushButton#saveBtn:hover {
    background-color: #2563eb;
}

QPushButton#saveBtn:disabled {
    background-color: #1e293b;
    color: #64748b;
}

QLineEdit {
    background-color: #1a1b23;
    border: 1px solid #2d2e3a;
    border-radius: 6px;
    padding: 8px;
    color: #f8fafc;
}

QLineEdit:focus {
    border-color: #3b82f6;
}

QComboBox {
    background-color: #1a1b23;
    border: 1px solid #2d2e3a;
    border-radius: 6px;
    padding: 5px;
    color: #f8fafc;
}

QProgressBar {
    border: 1px solid #2d2e3a;
    border-radius: 4px;
    background-color: #1a1b23;
    text-align: center;
    color: white;
}

QProgressBar::chunk {
    background-color: #3b82f6;
    border-radius: 3px;
}

QCheckBox {
    color: #f8fafc;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid #2d2e3a;
    border-radius: 4px;
    background-color: #1a1b23;
}

QCheckBox::indicator:checked {
    background-color: #3b82f6;
    border-color: #3b82f6;
}

QStatusBar {
    background-color: #1a1b23;
    color: #94a3b8;
    border-top: 1px solid #2d2e3a;
}

QFrame#settingsFrame {
    background-color: #1a1b23;
    border-radius: 8px;
    border: 1px solid #2d2e3a;
}
